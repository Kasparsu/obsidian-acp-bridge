{
	"name": "obsidian-acp-bridge",
	"version": "0.1.1",
	"description": "Obsidian plugin that bridges the vault to ACP-compatible coding agents.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": ["obsidian", "obsidian-plugin", "acp", "agent-client-protocol", "ai", "coding-agent"],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.0.0",
		"esbuild": "0.25.5",
		"esbuild-plugin-vue3": "^0.4.2",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vue-tsc": "^2.1.0"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "latest",
		"obsidian": "latest",
		"vue": "^3.5.0",
		"zod": "^3.23.0"
	}
}
